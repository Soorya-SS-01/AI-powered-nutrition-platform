        "sendTo": "={{ $json.email }}",
        "subject": "Nutrition Consultation Appointment Reminder",
        "message": "=<html>\n<body style=\"font-family: Arial, Helvetica, sans-serif; color: #333; line-height: 1.6;\">\n\n<p>Dear <strong>{{$json.client_name}}</strong>,</p>\n\n<p>We hope you are doing well.</p>\n\n<p>\nThis is a reminder about your upcoming nutrition consultation appointment.\nPlease find the details below:\n</p>\n\n<table style=\"border-collapse: collapse;\">\n  <tr>\n    <td><strong>Doctor</strong></td>\n    <td>: {{$json.doctor_name}}</td>\n  </tr>\n  <tr>\n    <td><strong>Date</strong></td>\n    <td>: {{$json.meeting_date}}</td>\n  </tr>\n  <tr>\n    <td><strong>Time</strong></td>\n    <td>: {{$json.meeting_time}}</td>\n  </tr>\n</table>\n\n<p>\n<strong>Google Meet Link:</strong><br><br>\n<a href=\"{{$json.meet_link}}\" target=\"_blank\"\nstyle=\"background:#2d7ff9;\ncolor:white;\npadding:10px 18px;\ntext-decoration:none;\nborder-radius:6px;\ndisplay:inline-block;\">\nJoin Google Meet\n</a>\n</p>\n\n<p>\nPlease ensure you join the meeting at the scheduled time.\n</p>\n\n<p>\nIf you have any questions, feel free to contact us.\n</p>\n\n<br>\n\n<p>\nBest Regards,<br>\n<strong>NutrifyMyDiet Team</strong>\n</p>\n\n</body>\n</html>",
