    {
      "parameters": {
        "jsCode": "// ================================\n// Get today's and tomorrow's date in IST\n// ================================\n\nconst now = new Date();\n\nconst todayStr = now.toLocaleDateString('en-CA', {\n  timeZone: 'Asia/Kolkata'\n});\n\nconst tomorrow = new Date(now);\ntomorrow.setDate(tomorrow.getDate() + 1);\n\nconst tomorrowStr = tomorrow.toLocaleDateString('en-CA', {\n  timeZone: 'Asia/Kolkata'\n});\n\nconsole.log(\"Today (IST):\", todayStr);\nconsole.log(\"Tomorrow (IST):\", tomorrowStr);\n\n// ================================\n// Filter meetings\n// ================================\n\nconst output = [];\n\nfor (const item of $input.all()) {\n\n  const meeting = item.json;\n\n  console.log(\"Checking Meeting:\", meeting.id);\n  console.log(\"Meeting Date:\", meeting.meeting_date);\n\n  // Extra safety\n  if (meeting.completed) {\n    continue;\n  }\n\n  // -------------------------\n  // Meeting is TODAY\n  // -------------------------\n  if (\n    meeting.meeting_date === todayStr &&\n    meeting.reminder_today_sent === false\n  ) {\n\n    console.log(\"Matched TODAY\");\n\n    output.push({\n      json: {\n        ...meeting,\n        reminder_type: \"today\"\n      }\n    });\n\n    continue;\n  }\n\n  // -------------------------\n  // Meeting is TOMORROW\n  // -------------------------\n  if (\n    meeting.meeting_date === tomorrowStr &&\n    meeting.reminder_day_before_sent === false\n  ) {\n\n    console.log(\"Matched TOMORROW\");\n\n    output.push({\n      json: {\n        ...meeting,\n        reminder_type: \"day_before\"\n      }\n    });\n  }\n}\n\nconsole.log(\"Meetings to remind:\", output.length);\n\nreturn output;"
      },
